{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-packages/main/packages/pi-permission-system/schemas/permissions.schema.json",

  "permissionReviewLog": true,
  "doublePressToConfirm": true,
  "toolInputPreviewMaxLength": 400,
  "toolTextSummaryMaxLength": 120,

  "permission": {
    "*": "allow",

    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.ssh/*": "ask",
      "~/.aws/*": "ask",
      "~/.gnupg/*": "ask",
      "*.pem": "ask",
      "*.key": "ask",
      "*id_rsa*": "ask"
    },

    "bash": {
      "*": "allow",
      "rm -rf /": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "chmod * 777 *": "deny",
      "chown * 777 *": "deny",
      "git push --force *": "ask",
      "git push --force-with-lease *": "allow",
      "git reset --hard *": "ask",
      "git clean -f *": "ask",
      "git checkout -- *": "ask",
      "dd *": "ask",
      "mkfs*": "deny",
      "shred *": "ask",
      "curl * | bash": "deny",
      "curl * | sh": "deny",
      "wget * | bash": "deny"
    },

    "external_directory": {
      "*": "ask",
      "~/.cargo/registry/*": "allow",
      "~/.npm/*": "allow"
    },

    "mcp": { "*": "ask", "mcp_status": "allow", "mcp_list": "allow" },
    "skill": { "*": "ask" }
  }
}
