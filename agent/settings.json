{
  "lastChangelogVersion": "0.80.10",
  "theme": "dark",
  "defaultProvider": "saigw-openai",
  "defaultModel": "gpt-5.6-sol",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-btw",
    "npm:@gotgenes/pi-permission-system",
    "npm:@pi-plugins/checkpoint",
    "npm:@quintinshaw/pi-dynamic-workflows"
  ],
  "defaultThinkingLevel": "high",
  "subagents": {
    "defaultModel": "saigw/glm-5.2",
    "agentOverrides": {
      "scout": {
        "model": "saigw/deepseek-v4-flash",
        "fallbackModels": ["saigw/minimax-m3", "saigw/deepseek-v4-flash"],
        "thinking": "low"
      },
      "researcher": {
        "model": "saigw/deepseek-v4-flash",
        "fallbackModels": ["saigw/minimax-m3", "saigw/deepseek-v4-flash"],
        "thinking": "medium"
      },
      "planner": {
        "model": "saigw/glm-5.2",
        "fallbackModels": ["saigw/kimi-k2.7-code", "saigw/qwen3.7-max"],
        "thinking": "high"
      },
      "worker": {
        "model": "saigw/glm-5.2",
        "fallbackModels": ["saigw/kimi-k2.7-code", "saigw/qwen3.7-max"],
        "thinking": "medium",
        "acceptanceRole": "writer"
      },
      "reviewer": {
        "model": "saigw/deepseek-v4-flash",
        "fallbackModels": ["saigw/minimax-m3", "saigw/deepseek-v4-flash"],
        "thinking": "medium",
        "acceptanceRole": "read-only"
      },
      "context-builder": {
        "model": "saigw/deepseek-v4-flash",
        "fallbackModels": ["saigw/minimax-m3", "saigw/deepseek-v4-flash"],
        "thinking": "medium"
      },
      "oracle": {
        "model": "saigw/glm-5.2",
        "fallbackModels": ["saigw/kimi-k2.7-code", "saigw/qwen3.7-max"],
        "thinking": "high"
      },
      "delegate": {
        "model": "saigw/glm-5.2",
        "fallbackModels": ["saigw/kimi-k2.7-code", "saigw/qwen3.7-max"]
      },
      "multimodal-looker": {
        "model": "saigw/kimi-k2.7-code",
        "fallbackModels": ["saigw/minimax-m3"]
      }
    }
  },
  "hideThinkingBlock": false
}

